---
import { flagship, gridProjects } from "../data/site";
const projectCount = flagship.length + gridProjects.length;
const stats = [
  { value: 17, dec: 0, label: "GitHub repos" },
  { value: projectCount, dec: 0, label: "Projects" },
  { value: 12, dec: 0, label: "Protocols" },
  { value: 5, dec: 0, label: "Programming languages" },
];
---
<section class="stats" aria-label="By the numbers">
  <div class="container stats__grid">
    {stats.map((s, i) => (
      <div class="stat reveal" style={`--i:${i}`}>
        <div class="stat__value"><span data-count={s.value} data-dec={s.dec}>0</span></div>
        <div class="stat__label">{s.label}</div>
      </div>
    ))}
  </div>
</section>
